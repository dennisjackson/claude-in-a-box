#!/bin/bash
# Connect to the dev container with a project folder mounted.
# Usage: cbx-connect <project-dir>
set -euo pipefail

# Resolve symlinks to find real script location (portable — no readlink -f)
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
PROJ_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

if [ $# -lt 1 ]; then
    echo "Usage: $(basename "$0") <project-dir>"
    echo "  Mount the given directory into the dev container and connect."
    exit 1
fi

PROJECT_DIR="$(cd "$1" && pwd)"
export PROJECT_DIR

# Per-project container identity — each project directory gets its own container
ID_LABEL="cbx.project=$PROJECT_DIR"
DC_ARGS="--workspace-folder $PROJ_DIR --id-label $ID_LABEL"

# Ensure .envrc exists (needed for API keys passed into the container)
if [ ! -f "$PROJ_DIR/.envrc" ]; then
    echo "==> No .envrc found — running setup..."
    "$PROJ_DIR/internal/setup-envrc.sh"
fi

# Source .envrc so variables are available to devcontainer up
# (${localEnv:...} in devcontainer.json reads from this process's environment)
# shellcheck disable=SC1091
source "$PROJ_DIR/.envrc"

# Check for a running container for this project
RUNNING=$(docker ps -q --filter "label=$ID_LABEL" 2>/dev/null || true)
if [ -n "$RUNNING" ]; then
    exec devcontainer exec $DC_ARGS bash
fi

# Check for a stopped container for this project
STOPPED=$(docker ps -aq --filter "label=$ID_LABEL" 2>/dev/null || true)
if [ -n "$STOPPED" ]; then
    # Stopped containers can't switch mounts — remove and recreate
    echo "==> Removing stopped container to (re)create with project mount..."
    docker rm -f "$STOPPED" >/dev/null
fi

# No usable container — create one
echo "==> Building container with project: $PROJECT_DIR"
devcontainer up $DC_ARGS
exec devcontainer exec $DC_ARGS bash
